obsidian-metadataPreset-saveAs =
    .label = Save As New Preset
obsidian-metadataPreset-delete =
    .label = Delete Current Preset
obsidian-metadataPreset-reset =
    .label = Reset Default Preset
obsidian-metadataPreset-resync =
    .label = Resync Linked Notes
obsidian-metadataPreset-help =
    .value = The field list is queried from Zotero item types and extended with bridge-specific derived fields. Only one preset can be active at a time; switching or saving a preset will resync all linked Obsidian notes with the active configuration.
