obsidian-dashboardDir-label = Dashboard Folder
obsidian-paths-help =
    .value = Once the Vault root is set, literature notes default to Vault/notes and assets default to Vault/assets/zotero. Only change them if you want a custom structure.
obsidian-templateSettings-title = Note Output
obsidian-noteTemplate-title = Note Template
obsidian-itemTemplate-label = Note Template
obsidian-itemTemplate-pick =
    .label = Choose Template
obsidian-itemTemplate-help =
    .value = This picker only lists [Item] templates. The template controls the initial body structure of a literature note, not which fields appear in Obsidian properties.
obsidian-frontmatter-title = Obsidian Property Fields
obsidian-frontmatter-help =
    .value = These switches control the extra bibliographic properties written into Obsidian frontmatter. Fixed fields stay in place for bridge identity and reading workflow; the options below are the extra properties you want to see.
obsidian-frontmatter-summary = Current preset: { $preset }. Fixed fields: { $fixed }. { $count } optional properties are currently enabled.
obsidian-frontmatter-preset-recommended-title = Recommended
obsidian-frontmatter-preset-recommended-description = Balanced for most literature-note workflows, keeping common metadata, jump links, and Zotero context together.
obsidian-frontmatter-preset-minimal-title = Minimal
obsidian-frontmatter-preset-minimal-description = Keep only the bridge identity and workflow essentials so the property pane stays clean.
obsidian-frontmatter-preset-dataview-title = Dataview-Friendly
obsidian-frontmatter-preset-dataview-description = Keeps the fields that are especially useful for Dataview tables, filters, and dashboards.
obsidian-frontmatter-preset-custom-title = Custom
obsidian-frontmatter-preset-active = Active
obsidian-frontmatter-preset-apply = Apply Preset
obsidian-frontmatter-group-reference = Bibliographic Info
obsidian-frontmatter-group-links = Links
obsidian-frontmatter-group-library = Zotero-Derived Info
obsidian-outputSettings-title = File and Sync
obsidian-fileNameTemplate-label = File Name Rule
obsidian-fileNameTemplate-help =
    .value = Available variable names: title, key, year, firstCreator, citationKey, publication, and itemType. Example: title--key. Changes apply on the next sync or resync.
obsidian-syncScope-label = Sync Scope
obsidian-syncScope-help =
    .value = Sync Now follows this scope: current selection, current list, or current library.
obsidian-syncScope-selection = Current Selection
obsidian-syncScope-currentList = Current List
obsidian-syncScope-library = Current Library
obsidian-autoSync =
    .label = Keep synced with Obsidian
obsidian-revealAfterSync =
    .label = Reveal exported file after sync
obsidian-openAfterSync =
    .label = Open the note in Obsidian after syncing
obsidian-dashboardAutoSetup =
    .label = Auto-setup dashboards during sync
obsidian-simple-help =
    .value = This page keeps only the most common Obsidian bridge settings. Advanced details such as vault name, dashboard folder, and metadata field presets use sensible defaults.
obsidian-contentSettings-title = Synced Content
obsidian-includeMetadata =
    .label = Include metadata and tags blocks
obsidian-includeAbstract =
    .label = Include abstract and translated abstract blocks
obsidian-includeHiddenInfo =
    .label = Include hidden fields block
obsidian-includeAnnotations =
    .label = Include PDF annotation blocks
obsidian-includeChildNotes =
    .label = Include bridged child-note content
obsidian-contentSettings-help =
    .value = These switches control which generated sections are written into managed Obsidian literature notes. User-maintained sections remain preserved.
obsidian-pickFile =
    .label = Choose File
obsidian-pickFolder =
    .label = Choose Folder
obsidian-syncNow =
    .label = Sync Now
obsidian-setupDashboards =
    .label = Set Up Dashboards
obsidian-repairManagedLinks =
    .label = Repair Managed Links
obsidian-dashboard-help =
    .value = This creates Research Dashboard, Topic Dashboard, and Reading Pipeline.base in the dashboard folder. Enable the Bases core plugin and the Dataview community plugin in Obsidian for the best experience.
obsidian-childNotes-title = Child Note Bridge Rules
obsidian-childNotes-tags-label = Match tags
obsidian-childNotes-help =
    .value = Only child notes carrying these tags are stitched into the managed Obsidian literature note. Separate tags with commas or semicolons and match them exactly.
obsidian-childNotes-promptSelect =
    .label = Prompt to choose child notes when one paper matches multiple notes
obsidian-childNotes-prompt-help =
    .value = No prompt is shown for batch syncs, multi-selection, zero matches, or a single matched child note. Those cases sync directly with the current tag rules.
obsidian-metadataPreset-title = Metadata Field Preset
obsidian-metadataPreset-active-label = Active preset
